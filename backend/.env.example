# AWS (Amazon Bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-west-2

# Resend (email sending)
RESEND_API_KEY=

# Google Sheets (persistent memory storage)
# 1. Create a service account in Google Cloud Console
# 2. Enable the Sheets API
# 3. Grant the service account edit access to your spreadsheet
# 4. Download the JSON key and paste its full content below
GOOGLE_SHEETS_ID=              # The part between /d/ and / in the spreadsheet URL
GOOGLE_SERVICE_ACCOUNT_JSON=   # {"type":"service_account","project_id":"..."}
